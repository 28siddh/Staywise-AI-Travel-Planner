<% layout("/layouts/boilerplate") %>

<style>
  body {
    background-color: #f8f9fa;
  }
  .itinerary-header {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.6)), url('https://images.unsplash.com/photo-1488085061387-422e29b40080?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80') center/cover;
    color: white;
    padding: 80px 20px;
    border-radius: 24px;
    margin-top: 20px;
    margin-bottom: 40px;
    text-align: center;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  .itinerary-header h1 {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 15px;
    text-transform: capitalize;
  }
  .trip-meta {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .meta-badge {
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    padding: 8px 16px;
    border-radius: 20px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }
  .overview-text {
    font-size: 1.15rem;
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 300;
  }
  
  .section-title {
    font-weight: 700;
    color: #222;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  
  /* Stays Grid */
  .stays-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 50px;
  }
  .stay-card {
    background: white;
    padding: 20px;
    border-radius: 16px;
    border: 1px solid #ebebeb;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }
  .stay-card h5 { font-weight: 700; color: #222; }
  .stay-price { color: #fe424d; font-weight: 600; font-size: 1.1rem; }
  
  /* Timeline */
  .day-card {
    background: white;
    border-radius: 16px;
    padding: 30px;
    margin-bottom: 30px;
    border: 1px solid #ebebeb;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }
  .day-title {
    font-weight: 800;
    color: #222;
    border-bottom: 2px solid #f1f1f1;
    padding-bottom: 15px;
    margin-bottom: 20px;
  }
  .activity-item {
    display: flex;
    margin-bottom: 20px;
  }
  .activity-time {
    min-width: 100px;
    font-weight: 700;
    color: #fe424d;
  }
  .activity-desc {
    color: #444;
    line-height: 1.6;
  }
  .daily-tip {
    background: #fff0f1;
    border-left: 4px solid #fe424d;
    padding: 15px 20px;
    border-radius: 0 8px 8px 0;
    margin-top: 20px;
    color: #b02a33;
    font-weight: 500;
  }
</style>

<div class="container mb-5">
  <% if (trip && trip.tripData) { %>
    
    <div class="itinerary-header">
      <h1><%= trip.location %></h1>
      <div class="trip-meta">
        <span class="meta-badge">📅 <%= trip.days %> Days</span>
        <span class="meta-badge">💰 Rs.<%= trip.budget.toLocaleString() %></span>
        <span class="meta-badge">🎒 <%= trip.style %></span>
      </div>
      <p class="overview-text"><%= trip.tripData.overview %></p>
    </div>

    <h3 class="section-title">🗺️ Your Day-by-Day Plan</h3>
    <% if (trip.tripData.days && trip.tripData.days.length > 0) { %>
      <% trip.tripData.days.forEach(day => { %>
        <div class="day-card">
          <h4 class="day-title">Day <%= day.day %>: <%= day.title %></h4>
          
          <% if (day.activities) { %>
            <% day.activities.forEach(activity => { %>
              <div class="activity-item">
                <div class="activity-time"><%= activity.time %></div>
                <div class="activity-desc"><%= activity.description %></div>
              </div>
            <% }) %>
          <% } %>

          <% if (day.tip) { %>
            <div class="daily-tip">
              💡 <strong>Pro Tip:</strong> <%= day.tip %>
            </div>
          <% } %>
        </div>
      <% }) %>
    <% } %>

  <% } else { %>
    <div class="alert alert-danger mt-5">
      <h4>Data Error</h4>
      <p>We couldn't load the AI data for this trip. It may have been corrupted.</p>
      <a href="/itinerary/my-trips" class="btn btn-outline-dark mt-3">Back to Trips</a>
    </div>
  <% } %>
</div>